<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="pallet">
    <storeData>
        <name>woolPallet</name>
        <image>dummy.png</image>
        <category>pallets</category>
        <brand>LIZARD</brand>
        <showInStore>false</showInStore>
        <canBeSold>false</canBeSold>
        <financeCategory>OTHER</financeCategory>
        <vertexBufferMemoryUsage>99328</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>22440</indexBufferMemoryUsage>
        <textureMemoryUsage>4194424</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
    </storeData>

    <base>
        <filename>$data/objects/pallets/woolPallet/woolPallet.i3d</filename>
        <size width="2" length="1.5" lengthOffset="0" />
        <canBeReset>false</canBeReset>
        <input allowed="false"/>
        <components>
            <component centerOfMass="0 0.1 0" solverIterationCount="10" mass="480"/>
        </components>
    </base>

    <animations>
        <animation name="woolAnimation">
            <part node="bag1"  startTime="0.000" endTime="0.001" visibility="false" />
            <part node="bag1"  startTime="0.001" endTime="1.000" visibility="true" />

            <part node="bag2"  startTime="0.000" endTime="0.333" visibility="false" />
            <part node="bag2"  startTime="0.333" endTime="1.000" visibility="true" />

            <part node="bag3"  startTime="0.000" endTime="0.666" visibility="false" />
            <part node="bag3"  startTime="0.666" endTime="1.000" visibility="true" />

            <part node="bag4"  startTime="0.000" endTime="0.999" visibility="false" />
            <part node="bag4"  startTime="0.999" endTime="1.000" visibility="true" />
        </animation>
    </animations>

    <fillUnit>
        <fillUnitConfigurations>
            <fillUnitConfiguration>
                <fillUnits removeVehicleIfEmpty="true">
                    <fillUnit unit="$l10n_unit_literShort" fillTypes="wool" capacity="1000">
                        <dashboard displayType="ANIMATION" valueType="fillLevel" animName="woolAnimation" />
                    </fillUnit>
                </fillUnits>
            </fillUnitConfiguration>
        </fillUnitConfigurations>
    </fillUnit>
    
    <dischargeable requiresTipOcclusionArea="false">
        <dischargeNode node="0>" emptySpeed="1000" fillUnitIndex="1" maxDistance="6" canStartDischargeAutomatically="true">
            <trigger node="dischargeTrigger" />
        </dischargeNode>
    </dischargeable>

    <dynamicMount triggerNode="dynamicMountTrigger" />
    
    <i3dMappings>
        <i3dMapping id="dynamicMountTrigger" node="0>0" />
        <i3dMapping id="bag1" node="0>1|0" />
        <i3dMapping id="bag2" node="0>1|1" />
        <i3dMapping id="bag3" node="0>1|2" />
        <i3dMapping id="bag4" node="0>1|3" />
        <i3dMapping id="dischargeTrigger" node="0>3" />
    </i3dMappings>
</vehicle>
