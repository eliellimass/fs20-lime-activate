      <Glossmap fileId="2"/>
    </Material>
  </Materials>


  <Shapes externalShapesFile="dual002.i3d.shapes">
  </Shapes>

  <Scene>
    <TransformGroup name="_dw_" collision="false" clipDistance="800" nodeId="1">
      <TransformGroup name="_01_" collision="false" clipDistance="800" nodeId="2">
        <Shape name="shape" shapeId="1" castsShadows="true" receiveShadows="true" materialIds="1" clipDistance="800" nodeId="3"/>
      </TransformGroup>
      <TransformGroup name="_02_" collision="false" clipDistance="800" nodeId="4">
        <Shape name="shape" shapeId="2" castsShadows="true" receiveShadows="true" materialIds="1" clipDistance="800" nodeId="5"/>
      </TransformGroup>
    </TransformGroup>
  </Scene>

  <UserAttributes>
  </UserAttributes>
</i3D>
