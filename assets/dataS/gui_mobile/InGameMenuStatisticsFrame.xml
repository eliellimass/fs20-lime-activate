<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="ingameMenuGameStats">
    <GuiElement type="bitmap" profile="uiInGameMenuPageHeader" id="pageHeader">
        <GuiElement type="empty" profile="uiInGameMenuHeaderSubPagingSelector"  id="subPageSelector">
            <GuiElement type="button" profile="uiInGameMenuSubPagingButtonLeft" id="subPagingButtonLeft" onClick="onClickSubPageSelection" />
            <GuiElement type="button" profile="uiInGameMenuSubPagingButtonRight" id="subPagingButtonRight" onClick="onClickSubPageSelection" />
        </GuiElement>
        <GuiElement type="text" profile="uiInGameMenuPagingTitle" id="pagingTitle" text="$l10n_ui_ingameMenuGameStats" />
    </GuiElement>

    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <GuiElement type="empty" profile="ingameMenuStatisticsContainer" id="statsContainer">
            <!-- Table header left -->
            <GuiElement type="boxLayout" profile="ingameMenuStatisticsTableHeaderBox" position="0px 0px" id="tableHeaderBox[1]">
                <GuiElement type="button" profile="ingameMenuStatisticsTableHeaderType" columnName="stat" text="$l10n_ui_statistic"/>
                <GuiElement type="button" profile="ingameMenuStatisticsTableHeader" columnName="sessionValue" text="$l10n_ui_session"/>
                <GuiElement type="button" profile="ingameMenuStatisticsTableHeader" columnName="totalValue" text="$l10n_ui_total"/>
            </GuiElement>

            <!-- Statistics table left -->
            <GuiElement type="table" profile="ingameMenuStatisticsTable" position="1px -104px" rowTemplateName="statisticsRowTemplate" updateChildrenOverlayState="false"
                    columnNames="stat sessionValue totalValue" id="statisticsTable[1]" periodicUpdate="true" updateInterval="5" onUpdate="updateStatistics"
                    handleFocus="false">
                <GuiElement type="listItem" profile="ingameMenuStatisticsRow" name="statisticsRowTemplate">
                    <GuiElement type="bitmap" profile="ingameMenuStatisticsRowBackground">
                        <GuiElement type="text" profile="ingameMenuStatisticsRowTypeCell" name="stat" onCreate="onDataBindStat"/>
                        <GuiElement type="text" profile="ingameMenuStatisticsRowCell" position="700px 0px" name="sessionValue" onCreate="onDataBindSessionValue"/>
                        <GuiElement type="text" profile="ingameMenuStatisticsRowCell" position="1234px 0px" name="totalValue" onCreate="onDataBindTotalValue"/>
                    </GuiElement>
                </GuiElement>
            </GuiElement>

            <GuiElement type="indexState" profile="selectionStateBoxDocked" id="pagingIndexState" stateElementTemplateId="circleTemplate">
                <GuiElement type="bitmap" profile="selectionStateDocked" id="circleTemplate"/>
            </GuiElement>
        </GuiElement>
    </GuiElement>
</GUI>
