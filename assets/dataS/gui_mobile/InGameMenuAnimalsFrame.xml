                                </GuiElement>
                            </GuiElement>
                            <GuiElement type="empty" profile="ingameMenuAnimalsProductivityRow" id="animalAttribute[6]">
                                <GuiElement type="empty" profile="ingameMenuAnimalsProductivityRowTextPanel">
                                    <GuiElement type="text" profile="ingameMenuAnimalsProductivityLabel" id="animalAttributeLabel[6]"/>
                                    <GuiElement type="text" profile="ingameMenuAnimalsProductivityValue" id="animalAttributeText[6]"/>
                                </GuiElement>
                            </GuiElement>
                            <GuiElement type="empty" profile="ingameMenuAnimalsProductivityRow" id="animalAttribute[7]">
                                <GuiElement type="empty" profile="ingameMenuAnimalsProductivityRowTextPanel">
                                    <GuiElement type="text" profile="ingameMenuAnimalsProductivityLabel" id="animalAttributeLabel[7]"/>
                                    <GuiElement type="text" profile="ingameMenuAnimalsProductivityValue" id="animalAttributeText[7]"/>
                                </GuiElement>
                            </GuiElement>
                            <GuiElement type="empty" profile="ingameMenuAnimalsProductivityRow" id="animalAttribute[8]">
                                <GuiElement type="empty" profile="ingameMenuAnimalsProductivityRowTextPanel">
                                    <GuiElement type="text" profile="ingameMenuAnimalsProductivityLabel" id="animalAttributeLabel[8]"/>
                                    <GuiElement type="text" profile="ingameMenuAnimalsProductivityValue" id="animalAttributeText[8]"/>
                                </GuiElement>
                            </GuiElement>
                        </GuiElement>
                    </GuiElement>

                    <!-- Vertical separator -->
                    <GuiElement type="bitmap" profile="lineSeparator" anchors="1 1 0.5 0.5" position="1px 0px" size="1dp 570px"/>
                </GuiElement>

                <!-- Animal Conditions and Requirements -->
                <GuiElement type="empty" profile="ingameMenuAnimalsDetailInputBox" position="1022px 0px" id="detailInputBox">
                    <GuiElement type="text" profile="ingameMenuAnimalsDetailTypeName" position="40px -32px" text="$l10n_ui_husbandryInformation" textResizeWidth="500px" textMaxWidth="500px"/>

                    <GuiElement type="boxLayout" profile="ingameMenuAnimalsRequirementsLayout" position="40px -110px" id="requirementsLayout">
                        <!-- Conditions -->
                        <GuiElement type="text" profile="ingameMenuAnimalsRequirementsHeader" id="conditionsHeader" text="$l10n_ui_animalConditions"/>

                        <GuiElement type="empty" profile="ingameMenuAnimalsRequirementsRow" id="conditionRow[1]">
