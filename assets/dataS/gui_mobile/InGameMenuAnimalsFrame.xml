                            </GuiElement>
                        </GuiElement>
                    </GuiElement>
                </GuiElement>

                <!-- Animal Description -->
                <GuiElement type="empty" profile="ingameMenuAnimalsDetailDescriptionBox" position="1px 4px" id="detailDescriptionBox" visible="false">
                    <GuiElement type="bitmap" profile="ingameMenuAnimalsDetailDescriptionIcon" position="24px 0px"/>
                    <GuiElement type="text" profile="ingameMenuAnimalsDetailDescriptionText" position="80px 0px" id="detailDescriptionText"/>
                </GuiElement>
            </GuiElement>

            <GuiElement type="bitmap" profile="ingameMenuContractsEmptyBox" id="noHusbandriesBox">
                <GuiElement type="text" profile="ingameMenuContractsEmptyText" text="$l10n_ui_noHusbandriesPlaced" />
            </GuiElement>

            <GuiElement type="indexState" profile="selectionStateBoxDocked" id="pagingIndexState" stateElementTemplateId="circleTemplate">
                <GuiElement type="bitmap" profile="selectionStateDocked" id="circleTemplate"/>
            </GuiElement>
