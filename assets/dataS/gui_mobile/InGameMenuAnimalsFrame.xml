<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI name="ingameMenuAnimals">
    <GuiElement type="bitmap" profile="uiInGameMenuPageHeader" id="pageHeader">
        <GuiElement type="empty" profile="uiInGameMenuHeaderSubPagingSelector"  id="subPageSelector">
            <GuiElement type="button" profile="uiInGameMenuSubPagingButtonLeft" id="subPagingButtonLeft" onClick="onClickSubPageSelection" />
            <GuiElement type="button" profile="uiInGameMenuSubPagingButtonRight" id="subPagingButtonRight" onClick="onClickSubPageSelection" />
        </GuiElement>
        <GuiElement type="text" profile="uiInGameMenuPagingTitle" id="pagingTitle" text="$l10n_ui_ingameMenuAnimals" />
    </GuiElement>

    <GuiElement type="empty" profile="uiInGameMenuFrame">
        <GuiElement type="empty" profile="ingameMenuCenterBox" id="animalsContainer">
            <!-- Animal Type List -->
            <GuiElement type="bitmap" profile="ingameMenuAnimalsListBox" id="animalsListBox">
                <GuiElement type="flowLayout" profile="ingameMenuAnimalsListHeaderBox" position="1px 0px">
                    <GuiElement type="text" profile="ingameMenuAnimalTableHeader" size="550px 101px" text="$l10n_ui_animal" textAlignment="left" textOffset="40px 0px" />
                    <GuiElement type="text" profile="ingameMenuAnimalTableHeader" size="420px 101px" text="" />
                    <GuiElement type="text" profile="ingameMenuAnimalTableHeader" size="420px 101px" text="" />
                    <GuiElement type="text" profile="ingameMenuAnimalTableHeader" size="300px 101px" text="$l10n_ui_amount"/>
                </GuiElement>

                <GuiElement type="stableList" profile="ingameMenuAnimalsList" position="1px -102px" itemTemplateId="animalListItemTemplate" onSelectionChanged="onListSelectionChanged" id="animalList" onDoubleClick="onListDoubleClick">
                    <GuiElement type="listItem" profile="ingameMenuAnimalsListItem" id="animalListItemTemplate" >
                        <GuiElement type="bitmap" profile="ingameMenuAnimalsListItemTypeIcon" size="44px 44px" position="40px 0px" name="animalTypeIcon"/>
                        <GuiElement type="text" profile="ingameMenuAnimalsListItemTypeName" size="550px 101px" position="92px 0px" text="ANIMAL" name="animalName"/>
                        <GuiElement type="text" profile="ingameMenuAnimalsListItemTypeCount" size="300px 101px" position="1390px 0px" text="" name="animalCount"/>

                        <GuiElement type="text" profile="ingameMenuAnimalsListItemStatusLabel" size="400px 101px" position="642px 0px" text="Status" name="animalStatusLabel" />
                        <GuiElement type="text" profile="ingameMenuAnimalsListItemStatusValue" size="420px 101px" position="970px 0px" text="50%" name="animalStatusValue"/>

                        <GuiElement type="text" profile="ingameMenuAnimalsListItemTypeName" position="20px -18px" text="HUSBANDRY" name="husbandryName"/>
                    </GuiElement>
                </GuiElement>
            </GuiElement>

            <!-- Animal (Husbandry) Detail Information -->
            <GuiElement type="bitmap" profile="ingameMenuAnimalsDetailsBox" id="detailsBox">
                <GuiElement type="empty" profile="ingameMenuAnimalsDetailNameBox">
                    <GuiElement type="text" profile="ingameMenuAnimalsDetailTypeName" position="40px -40px" id="animalDetailTypeNameText" text="Animal Type"/>
                    <GuiElement type="bitmap" profile="ingameMenuAnimalsDetailTypeImage" position="0px -90px" id="animalDetailTypeImage"/>

                    <!-- Vertical separator -->
                    <GuiElement type="bitmap" profile="lineSeparator" anchors="1 1 0.5 0.5" position="1px 0px" size="1dp 570px"/>
                </GuiElement>

                <!-- Animal Output / Value Information -->
                <GuiElement type="empty" profile="ingameMenuAnimalsDetailOutputBox" position="478px 0px" id="detailOutputBox">
                    <GuiElement type="text" profile="ingameMenuAnimalsDetailTypeName" position="40px -40px" text="$l10n_ui_animalInformation"/>

                    <GuiElement type="text" profile="ingameMenuAnimalsDetailTypeCount" position="-40px -32px" id="animalDetailTypeCountText" text="123" visible="false" />
                    <GuiElement type="text" profile="ingameMenuAnimalsDetailTypeValue" position="-40px -32px" id="animalDetailTypeValueText" text="$ 45'123" visible="false" />

                    <!-- Livestock Attributes -->
                    <GuiElement type="empty" profile="ingameMenuAnimalsDetailAttributesBox" position="1px -10px" visible="false" id="animalDetailLivestockBox">

                        <GuiElement type="boxLayout" profile="ingameMenuAnimalsProductivityLayout" position="40px 0px" id="livestockAttributesLayout">

                            <GuiElement type="empty" profile="ingameMenuAnimalsProductivityRow" id="animalAttribute[1]">
                                <GuiElement type="empty" profile="ingameMenuAnimalsProductivityRowTextPanel">
                                    <GuiElement type="text" profile="ingameMenuAnimalsProductivityLabel" id="animalAttributeLabel[1]"/>
                                    <GuiElement type="text" profile="ingameMenuAnimalsProductivityValue" id="animalAttributeText[1]"/>
                                </GuiElement>
                            </GuiElement>
                            <GuiElement type="empty" profile="ingameMenuAnimalsProductivityRow" id="animalAttribute[2]">
