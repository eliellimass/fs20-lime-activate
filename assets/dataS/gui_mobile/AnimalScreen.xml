<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUI onOpen="onOpen" onClose="onClose" onCreate="onCreate">
    <GuiElement type="bitmap" profile="uiFullInGameBackground"/>

    <GuiElement type="bitmap" profile="uiElementContainerFullScreenSpanning">
        <GuiElement type="empty" profile="animalScreenMainBox" id="container">

            <GuiElement type="empty" profile="animalDealerListBoxLeft">
                <GuiElement type="text" profile="animalHeaderText" id="headerSource" text="$l10n_animals_dealer"/>

                <GuiElement type="stableList" profile="animalDealerList" itemTemplateId="itemTemplateSource" onSelectionChanged="onSourceListSelectionChanged" onDoubleClick="onSourceListDoubleClick" id="listSource" focusChangeRight="targetList" focusId="sourceList" >
                    <GuiElement type="listItem" profile="animalListItem" id="itemTemplateSource" >
                        <GuiElement type="bitmap" profile="animalListItemIcon" name="icon"/>
                        <GuiElement type="text" profile="animalListItemName" text="Type" name="name" />
                        <GuiElement type="text" profile="animalListItemType" text="State" name="state" />
                        <GuiElement type="text" profile="animalListItemPrice" text="500€" name="price" />
                    </GuiElement>
                </GuiElement>

                <GuiElement type="slider" profile="sliderInvisible" id="listSlider" dataElementId="listSource" handleFocus="false">
                    <GuiElement type="button" profile="animalListScrollButtonDown" handleFocus="false" />
                    <GuiElement type="button" profile="animalListScrollButtonUp" handleFocus="false" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="bitmap" profile="animalDealerListBoxCenter">
                <GuiElement type="bitmap" profile="animalIcon" id="animalIcon"/>
                <GuiElement type="text" profile="animalDealerIconTitle" id="animalTitle" text="Franzi"/>
                <GuiElement type="text" profile="animalDealerIconPrice" id="animalPrice" text="2.500 €"/>

                <GuiElement type="empty" size="720px 250px" id="infoBox"  positionOrigin="bottomCenter" screenAlign="bottomCenter">
                    <GuiElement type="text"  profile="animalDealerMoneyTitle" position="70px 240px" text="$l10n_button_buy:" />
                    <GuiElement type="text"  profile="animalDealerMoneyValue" position="-70px 240px" text="15.000 €" id="infoBuyPrice"/>

                    <GuiElement type="text"  profile="animalDealerMoneyTitle" position="70px 200px" text="$l10n_button_sell:" />
                    <GuiElement type="text"  profile="animalDealerMoneyValue" position="-70px 200px" text="15.000 €" id="infoSellPrice"/>

                    <GuiElement type="text"  profile="animalDealerMoneyTitle" position="70px 160px" text="$l10n_shop_fee:" />
                    <GuiElement type="text"  profile="animalDealerMoneyValue" position="-70px 160px" text="15.000 €" id="infoFee" />

                    <GuiElement type="text"  profile="animalDealerMoneyTitle" position="70px 120px" text="$l10n_ui_total:" />
                    <GuiElement type="text"  profile="animalDealerMoneyValue" position="-70px 120px" text="15.000 €" id="infoTotal"/>

                    <GuiElement type="bitmap" profile="animalDealerInfoIcon" />
                    <GuiElement type="text"  profile="animalDealerInfo" text="$l10n_shop_transportationFee" />
                </GuiElement>
            </GuiElement>

            <GuiElement type="empty" profile="animalDealerListBoxRight">
                <GuiElement type="text" profile="animalHeaderText" id="headerTarget" text="$l10n_animals_dealer"/>

                <GuiElement type="stableList" profile="animalDealerList" itemTemplateId="itemTemplateTarget" onSelectionChanged="onTargetListSelectionChanged" onDoubleClick="onTargetListDoubleClick" id="listTarget" focusId="targetList" focusChangeLeft="sourceList">
                    <GuiElement type="listItem" profile="animalListItem" id="itemTemplateTarget" >
                        <GuiElement type="bitmap" profile="animalListItemIcon" name="icon"/>
                        <GuiElement type="text" profile="animalListItemName" text="Name" name="name" />
                        <GuiElement type="text" profile="animalListItemType" text="Type" name="state" />
                        <GuiElement type="text" profile="animalListItemPrice" text="500€" name="price" />
                    </GuiElement>
                </GuiElement>

                <GuiElement type="slider" profile="sliderInvisible" id="listSlider" dataElementId="listTarget" handleFocus="false">
                    <GuiElement type="button" profile="animalListScrollButtonDown" handleFocus="false" />
                    <GuiElement type="button" profile="animalListScrollButtonUp" handleFocus="false" />
                </GuiElement>

                <GuiElement type="threePartBitmap" profile="shopBalanceDocked">
                    <GuiElement type="text" profile="shopBalance" text="$l10n_ui_balance:" anchors="0 0 0.5 0.5" id="balanceTitleElement" />
                    <GuiElement type="text" profile="shopMoney" text="0" anchors="1 1 0.5 0.5" id="balanceElement"/>
                </GuiElement>
            </GuiElement>

            <GuiElement type="flowLayout" profile="buttonBoxDocked">
                <GuiElement type="button" profile="buttonBack" text="$l10n_button_back" onClick="onClickBack" />
                <GuiElement type="button" profile="buttonSwap" text="$l10n_button_move" onClick="onClickOk" />
                <GuiElement type="button" profile="buttonActivate" text="$l10n_button_confirm" onClick="onClickActivate" id="buttonApply"/>
            </GuiElement>
        </GuiElement>
    </GuiElement>
</GUI>
