<?xml version="1.0" encoding="utf-8" standalone="no" ?>

<animation>
	<states>
		<state index="0" type="blend" clip0="5" clip1="6" start="500" speed="1" name="walk" />
		<state index="1" type="blend" clip0="2" clip1="3" start="500" speed="1" name="run" />
		<state index="2" type="single" clip0="1" start="0" speed="1" name="idle" />
		<state index="3" type="single" clip0="0" start="0" speed="1" name="eat" />
		<state index="4" type="single" clip0="1" start="0" speed="1" name="sleep" />
		<state index="5" type="single" clip0="1" start="0" speed="1" name="chew" />
		<state index="6" type="single" clip0="4" start="0" speed="1" name="turnLeft" />
		<state index="7" type="single" clip0="7" start="0" speed="1" name="turnRight" />
	</states>
	<transitions defaultBlendTime="1250">
		<transition index="0" state0="2" state1="3" clip="8" name="idleEat" />
		<transition index="1" state0="3" state1="2" clip="9" name="eatIdle" />
		<transition index="2" state0="6" state1="0" blendTime="250" name="turnLeftWalk" />
		<transition index="3" state0="7" state1="0" blendTime="250" name="turnRightWalk" />		
	</transitions>
</animation>